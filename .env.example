# ========================
# PostgreSQL
# ========================
POSTGRES_DB=pm_bot_db
POSTGRES_USER=pm_bot
POSTGRES_PASSWORD=changeme_this_in_production

# ========================
# Database & Redis URLs (used by Plane services)
# ========================
DATABASE_URL=postgresql://pm_bot:changeme_this_in_production@postgres:5432/pm_bot_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ========================
# Plane.so
# ========================
PLANE_SECRET_KEY=generate_a_long_random_string_here
PLANE_WEB_URL=http://localhost:8003
PLANE_ENABLE_EMAIL_PASSWORD_LOGIN=1
PLANE_ENABLE_SIGNUP=1
PLANE_ENABLE_MAGIC_LINK_LOGIN=0
PLANE_ADMIN_PASSWORD=admin_temp_password_change_me
GUNICORN_WORKERS=1

# ========================
# Storage (local by default, set USE_S3=0)
# ========================
STORAGE_TYPE=local
USE_S3=0
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
